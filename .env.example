# Скопируйте в .env.local и заполните значения.
# Документация: https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

# Публичные переменные (доступны в браузере, префикс NEXT_PUBLIC_)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Только на сервере (без NEXT_PUBLIC_ — не попадут в клиентский бандл)
# API_KEY=
